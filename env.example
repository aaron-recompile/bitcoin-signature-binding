# Copy to `.env` in repo root (or `binding/`). File `.env` is gitignored.
# Used only by optional Signet scripts (`binding/signet/`).
#
#   cp env.example .env

# WIF private key for Signet demo spends (Signet-only; never reuse mainnet keys)
BINDING_DEMO_WIF=
# bitcoind -signet datadir (directory containing bitcoin.conf)
INQUISITION_DATADIR=
# Leave empty to use your node’s default signet RPC port; set if you use a custom -rpcport
INQUISITION_RPC_PORT=
# Wallet name for -rpcwallet= (must exist on your node; `lab` is only an example)
INQUISITION_RPC_WALLET=lab
# BITCOIN_CLI=bitcoin-cli
